{
  "name": "website-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "marked": "^18.0.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "gitleaks-secret-scanner": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "sharp@0.34.5": true,
    "gitleaks-secret-scanner@2.1.1": true
  },
  "overrides": {
    "vite": "^7"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,json,astro,md}": "prettier --write --ignore-unknown",
    "ignore": [
      "node_modules",
      "dist",
      ".astro"
    ]
  }
}
